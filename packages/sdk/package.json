{
  "name": "@beampay/sdk",
  "version": "0.1.0",
  "description": "Merchant SDK for BeamPay — typed router calls, webhook verification, signature helpers",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BeamPayFun/beam-libs.git",
    "directory": "packages/sdk"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@beampay/schemas": "workspace:*",
    "@beampay/common": "workspace:*",
    "@beampay/contracts-abi": "workspace:*"
  },
  "peerDependencies": {
    "viem": "^2.21.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "viem": "^2.21.0",
    "hono": "^4.6.0"
  }
}
