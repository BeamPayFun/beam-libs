  "repository": {
    "type": "git",
    "url": "git+https://github.com/BeamPayFun/beam-libs.git",
    "directory": "packages/schemas"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "zod": "^3.23.0"
  }
}
